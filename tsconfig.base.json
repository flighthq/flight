{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitOverride": true,
    "useDefineForClassFields": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "noEmitOnError": true,
    "paths": {
      "@flighthq/application": ["./packages/application/src/index.ts"],
      "@flighthq/application/*": ["./packages/application/src/*"],
      "@flighthq/assets": ["./packages/assets/src/index.ts"],
      "@flighthq/filters": ["./packages/filters/src/index.ts"],
      "@flighthq/filters/*": ["./packages/filters/src/*"],
      "@flighthq/filters-webgl": ["./packages/filters-webgl/src/index.ts"],
      "@flighthq/filters-webgl/*": ["./packages/filters-webgl/src/*"],
      "@flighthq/filters-webgpu": ["./packages/filters-webgpu/src/index.ts"],
      "@flighthq/filters-webgpu/*": ["./packages/filters-webgpu/src/*"],
      "@flighthq/assets-loader": ["./packages/assets-loader/src/index.ts"],
      "@flighthq/assets-loader/*": ["./packages/assets-loader/src/*"],
      "@flighthq/assets/*": ["./packages/assets/src/*"],
      "@flighthq/sdk": ["./packages/sdk/src/index.ts"],
      "@flighthq/sdk/*": ["./packages/sdk/src/*"],
      "@flighthq/entity": ["./packages/entity/src/index.ts"],
      "@flighthq/entity/*": ["./packages/entity/src/*"],
      "@flighthq/geometry": ["./packages/geometry/src/index.ts"],
      "@flighthq/geometry/*": ["./packages/geometry/src/*"],
      "@flighthq/image-cache": ["./packages/image-cache/src/index.ts"],
      "@flighthq/image-cache/*": ["./packages/image-cache/src/*"],
      "@flighthq/input": ["./packages/input/src/index.ts"],
      "@flighthq/input/*": ["./packages/input/src/*"],
      "@flighthq/interaction": ["./packages/interaction/src/index.ts"],
      "@flighthq/interaction/*": ["./packages/interaction/src/*"],
      "@flighthq/materials": ["./packages/materials/src/index.ts"],
      "@flighthq/materials/*": ["./packages/materials/src/*"],
      "@flighthq/particles": ["./packages/particles/src/index.ts"],
      "@flighthq/particles/*": ["./packages/particles/src/*"],
      "@flighthq/particles-formats": ["./packages/particles-formats/src/index.ts"],
      "@flighthq/particles-formats/*": ["./packages/particles-formats/src/*"],
      "@flighthq/media": ["./packages/media/src/index.ts"],
      "@flighthq/media/*": ["./packages/media/src/*"],
      "@flighthq/render-canvas": ["./packages/render-canvas/src/index.ts"],
      "@flighthq/render-canvas/*": ["./packages/render-canvas/src/*"],
      "@flighthq/render": ["./packages/render/src/index.ts"],
      "@flighthq/render/*": ["./packages/render/src/*"],
      "@flighthq/render-dom": ["./packages/render-dom/src/index.ts"],
      "@flighthq/render-dom/*": ["./packages/render-dom/src/*"],
      "@flighthq/render-webgl": ["./packages/render-webgl/src/index.ts"],
      "@flighthq/render-webgl/*": ["./packages/render-webgl/src/*"],
      "@flighthq/render-webgpu": ["./packages/render-webgpu/src/index.ts"],
      "@flighthq/render-webgpu/*": ["./packages/render-webgpu/src/*"],
      "@flighthq/node": ["./packages/node/src/index.ts"],
      "@flighthq/node/*": ["./packages/node/src/*"],
      "@flighthq/displayobject": ["./packages/displayobject/src/index.ts"],
      "@flighthq/displayobject/*": ["./packages/displayobject/src/*"],
      "@flighthq/sprite": ["./packages/sprite/src/index.ts"],
      "@flighthq/sprite/*": ["./packages/sprite/src/*"],
      "@flighthq/world": ["./packages/world/src/index.ts"],
      "@flighthq/world/*": ["./packages/world/src/*"],
      "@flighthq/signals": ["./packages/signals/src/index.ts"],
      "@flighthq/signals/*": ["./packages/signals/src/*"],
      "@flighthq/spritesheet": ["./packages/spritesheet/src/index.ts"],
      "@flighthq/spritesheet/*": ["./packages/spritesheet/src/*"],
      "@flighthq/spritesheet-formats": ["./packages/spritesheet-formats/src/index.ts"],
      "@flighthq/spritesheet-formats/*": ["./packages/spritesheet-formats/src/*"],
      "@flighthq/surface": ["./packages/surface/src/index.ts"],
      "@flighthq/surface/*": ["./packages/surface/src/*"],
      "@flighthq/surface-filters": ["./packages/surface-filters/src/index.ts"],
      "@flighthq/surface-filters/*": ["./packages/surface-filters/src/*"],
      "@flighthq/timeline": ["./packages/timeline/src/index.ts"],
      "@flighthq/timeline/*": ["./packages/timeline/src/*"],
      "@flighthq/timeline-spritesheet": ["./packages/timeline-spritesheet/src/index.ts"],
      "@flighthq/timeline-spritesheet/*": ["./packages/timeline-spritesheet/src/*"],
      "@flighthq/tween": ["./packages/tween/src/index.ts"],
      "@flighthq/tween/*": ["./packages/tween/src/*"],
      "@flighthq/tween-easing": ["./packages/tween-easing/src/index.ts"],
      "@flighthq/tween-easing/*": ["./packages/tween-easing/src/*"],
      "@flighthq/text-layout": ["./packages/text-layout/src/index.ts"],
      "@flighthq/text-layout/*": ["./packages/text-layout/src/*"],
      "@flighthq/text-input": ["./packages/text-input/src/index.ts"],
      "@flighthq/text-input/*": ["./packages/text-input/src/*"],
      "@flighthq/types": ["./packages/types/src/index.ts"],
      "@flighthq/types/*": ["./packages/types/src/*"]
    },
    "types": ["@testing-library/jest-dom", "vitest/globals", "@webgpu/types"] // Include Vitest globals and WebGPU types for type-checking
  },
  "include": ["./packages/*/src"],
  "exclude": ["node_modules", "dist", ".claude"]
}
