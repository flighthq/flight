{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitOverride": true,
    "useDefineForClassFields": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@flighthq/assets": ["packages/assets/src/index.ts"],
      "@flighthq/assets/*": ["packages/assets/src/*"],
      "@flighthq/flight": ["packages/flight/src/index.ts"],
      "@flighthq/flight/*": ["packages/flight/src/*"],
      "@flighthq/geom": ["packages/geom/src/index.ts"],
      "@flighthq/geom/*": ["packages/geom/src/*"],
      "@flighthq/interaction": ["packages/interaction/src/index.ts"],
      "@flighthq/interaction/*": ["packages/interaction/src/*"],
      "@flighthq/materials": ["packages/materials/src/index.ts"],
      "@flighthq/materials/*": ["packages/materials/src/*"],
      "@flighthq/render-canvas": ["packages/render/canvas/src/index.ts"],
      "@flighthq/render-canvas/*": ["packages/render/canvas/src/*"],
      "@flighthq/render-core": ["packages/render/core/src/index.ts"],
      "@flighthq/render-core/*": ["packages/render/core/src/*"],
      "@flighthq/scene-graph-stage": ["packages/scene/graph/stage/src/index.ts"],
      "@flighthq/scene-graph-stage/*": ["packages/scene/graph/stage/src/*"],
      "@flighthq/timeline": ["packages/timeline/src/index.ts"],
      "@flighthq/timeline/*": ["packages/timeline/src/*"],
      "@flighthq/types": ["packages/types/src/index.ts"],
      "@flighthq/types/*": ["packages/types/src/*"],
      "@flighthq/scene-graph-world": ["packages/scene-graph-world/src/index.ts"],
      "@flighthq/scene-graph-world/*": ["packages/scene-graph-world/src/*"]
    },
    "types": ["vitest/globals"] // Include Vitest globals for type-checking
  },
  "include": ["packages/*/src"],
  "exclude": ["node_modules", "dist"]
}
