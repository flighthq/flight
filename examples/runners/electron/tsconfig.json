{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["electron-vite/node"],
    "noEmit": true
  },
  "include": ["src", "electron.vite.config.ts"]
}
