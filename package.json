{
  "name": "flight",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/**",
    "examples/**",
    "tests/*",
    "tools/*",
    "apps/site/*"
  ],
  "scripts": {
    "api": "tsx ./scripts/api.ts",
    "api:json": "tsx ./scripts/api.ts --json",
    "build": "tsc -b tsconfig.build.json",
    "build:check": "npm run packages:check && npm run typecheck",
    "build:clean": "npm run clean && npm run build",
    "build:electron-harness": "npm run build --workspace=tools/electron-harness",
    "build:examples": "npm run build --workspace=examples/**",
    "build:landing": "npm run build --workspace=apps/site/landing",
    "build:reference": "npm run build --workspace=tools/reference",
    "build:rust": "npm run build:rust:core",
    "build:rust:all": "cargo build --workspace",
    "build:rust:core": "tsx ./scripts/cargo-tier.ts core build",
    "build:rust:extras": "tsx ./scripts/cargo-tier.ts extras build",
    "build:site": "tsx ./scripts/build-site.ts",
    "build:wasm": "tsx ./scripts/build-wasm.ts",
    "capture:baseline": "npm run capture:examples:baseline && npm run capture:functional:baseline && npm run capture:reference:baseline && npm run capture:site:baseline",
    "capture:check": "npm run capture:examples:check && npm run capture:functional:check && npm run capture:reference:check && npm run capture:site:check",
    "capture:examples": "tsx ./scripts/capture.ts --tool=examples",
    "capture:examples:baseline": "tsx ./scripts/capture.ts --tool=examples --update-baseline",
    "capture:examples:check": "tsx ./scripts/capture.ts --tool=examples --fail-on-changed",
    "capture:examples:watch": "tsx ./scripts/watch-capture.ts --tool=examples",
    "capture:functional": "tsx ./scripts/capture.ts --tool=functional",
    "capture:functional:baseline": "tsx ./scripts/capture.ts --tool=functional --update-baseline",
    "capture:functional:check": "tsx ./scripts/capture.ts --tool=functional --fail-on-changed",
    "capture:functional:watch": "tsx ./scripts/watch-capture.ts --tool=functional",
    "capture:reference": "tsx ./scripts/capture.ts --tool=reference",
    "capture:reference:baseline": "tsx ./scripts/capture.ts --tool=reference --update-baseline",
    "capture:reference:check": "tsx ./scripts/capture.ts --tool=reference --fail-on-changed",
    "capture:reference:watch": "tsx ./scripts/watch-capture.ts --tool=reference",
    "capture:site": "tsx ./scripts/capture.ts --tool=site",
    "capture:site:baseline": "tsx ./scripts/capture.ts --tool=site --update-baseline",
    "capture:site:check": "tsx ./scripts/capture.ts --tool=site --fail-on-changed",
    "capture:site:watch": "tsx ./scripts/watch-capture.ts --tool=site",
    "check": "npm run packages:check && npm run typecheck && npm run lint && npm run format:check && npm run order:check && npm run exports:check",
    "check:rust": "npm run check:rust:core",
    "check:rust:all": "npm run lint:rust:all && npm run format:rust:check",
    "check:rust:core": "npm run lint:rust:core && npm run format:rust:check",
    "check:rust:extras": "npm run lint:rust:extras && npm run format:rust:check",
    "check:wasm": "tsx ./scripts/check-wasm-contract.ts",
    "ci": "npm run build:wasm && npm run check:wasm && npm run build && npm run check && npm run test && npm run size && npm run test:functional && npm run test:examples && npm run test:reference",
    "clean": "tsc -b tsconfig.build.json --clean",
    "clean:examples": "npm run clean --workspace=examples/** --if-present",
    "clean:rust": "cargo clean",
    "clean:wasm": "tsx ./scripts/clean-wasm.ts",
    "dev:electron-harness": "npm run dev --workspace=tools/electron-harness",
    "dev:examples": "npm run dev --workspace=tools/examples",
    "dev:functional": "npm run dev --workspace=tools/functional",
    "dev:landing": "npm run dev --workspace=apps/site/landing",
    "dev:reference": "npm run dev --workspace=tools/reference",
    "electron-harness": "npm run dev:electron-harness",
    "examples": "npm run dev:examples",
    "exports:check": "tsx ./scripts/completeness.ts",
    "exports:check:json": "tsx ./scripts/completeness.ts --json",
    "fix": "npm run order:fix && npm run lint:fix && npm run format",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "format:rust": "cargo fmt --all",
    "format:rust:check": "cargo fmt --all --check",
    "functional": "npm run dev:functional",
    "init:worktree": "npm install && chmod -R 777 node_modules",
    "install:rust": "tsx ./scripts/install-rust.ts",
    "install:wasm": "npm run install:rust",
    "landing": "npm run dev:landing",
    "lint": "eslint -c eslint.config.ts . --cache --max-warnings=0 --no-warn-ignored",
    "lint:fix": "eslint -c eslint.config.ts . --fix --no-warn-ignored",
    "lint:rust": "npm run lint:rust:core",
    "lint:rust:all": "cargo clippy --workspace --all-targets -- -D warnings",
    "lint:rust:core": "tsx ./scripts/cargo-tier.ts core clippy --all-targets -- -D warnings",
    "lint:rust:extras": "tsx ./scripts/cargo-tier.ts extras clippy --all-targets -- -D warnings",
    "order": "tsx ./scripts/order.ts",
    "order:check": "tsx ./scripts/order.ts --check",
    "order:check:json": "tsx ./scripts/order.ts --check --json",
    "order:fix": "tsx ./scripts/order.ts --fix",
    "packages:check": "tsx ./scripts/packages.ts",
    "packages:check:json": "tsx ./scripts/packages.ts --json",
    "rust:conformance": "tsx ./scripts/rust-conformance.ts",
    "rust:conformance:json": "tsx ./scripts/rust-conformance.ts --json",
    "precommit": "lint-staged",
    "prepare": "husky",
    "prepush": "tsx ./scripts/prepush.ts",
    "preview:site": "cross-env PAGES_BASE=/ npm run build:site && npx -y serve tools/site",
    "reference": "npm run dev:reference",
    "sbx:whitelist": "sbx policy allow network cdn.playwright.dev,playwright.download.prss.microsoft.com,github.com,objects.githubusercontent.com,release-assets.githubusercontent.com,static.crates.io,crates.io",
    "size": "tsx ./scripts/size.ts",
    "size:baseline": "cross-env UPDATE_BASELINE=1 tsx ./scripts/size.ts",
    "size:json": "tsx ./scripts/size.ts report=json",
    "start:electron-harness": "npm run start --workspace=tools/electron-harness",
    "test": "vitest run --project=!size",
    "test:baseline": "npm run test:regression:baseline",
    "test:coverage": "vitest run --coverage --project=!size",
    "test:examples": "npm run test:examples:smoke && tsx ./scripts/compare-render.ts --tool=examples --frames=30",
    "test:examples:baseline": "npm run test:examples:regression:baseline",
    "test:examples:parity": "tsx ./scripts/compare-render.ts --tool=examples --frames=30 --no-regression",
    "test:examples:regression": "tsx ./scripts/compare-render.ts --tool=examples --frames=30 --no-parity",
    "test:examples:regression:baseline": "tsx ./scripts/compare-render.ts --tool=examples --frames=30 --update-fingerprints",
    "test:examples:smoke": "tsx ./scripts/capture.ts --tool=examples --frames=30 --fail-on-error",
    "test:functional": "npm run test:functional:smoke && tsx ./scripts/compare-render.ts --tool=functional",
    "test:functional:baseline": "npm run test:functional:regression:baseline",
    "test:functional:parity": "tsx ./scripts/compare-render.ts --tool=functional --no-regression",
    "test:functional:regression": "tsx ./scripts/compare-render.ts --tool=functional --no-parity",
    "test:functional:regression:baseline": "tsx ./scripts/compare-render.ts --tool=functional --update-fingerprints",
    "test:functional:smoke": "tsx ./scripts/capture.ts --tool=functional --frames=1 --fail-on-error",
    "test:parity": "npm run test:functional:parity && npm run test:examples:parity && npm run test:reference:parity",
    "test:reference": "npm run test:reference:smoke && tsx ./scripts/compare-render.ts --tool=reference",
    "test:reference:baseline": "npm run test:reference:regression:baseline",
    "test:reference:parity": "tsx ./scripts/compare-render.ts --tool=reference --no-regression",
    "test:reference:regression": "tsx ./scripts/compare-render.ts --tool=reference --no-parity",
    "test:reference:regression:baseline": "tsx ./scripts/compare-render.ts --tool=reference --update-fingerprints",
    "test:reference:smoke": "tsx ./scripts/capture.ts --tool=reference --frames=1 --fail-on-error",
    "test:regression": "npm run test:functional:regression && npm run test:examples:regression && npm run test:reference:regression",
    "test:regression:baseline": "npm run test:functional:regression:baseline && npm run test:examples:regression:baseline && npm run test:reference:regression:baseline",
    "test:rust": "npm run test:rust:core",
    "test:rust:all": "cargo test --workspace",
    "test:rust:core": "tsx ./scripts/cargo-tier.ts core test",
    "test:rust:extras": "tsx ./scripts/cargo-tier.ts extras test",
    "test:size": "tsx ./scripts/test-size.ts",
    "test:size:baseline": "cross-env UPDATE_BASELINE=1 tsx ./scripts/test-size.ts",
    "test:smoke": "npm run test:functional:smoke && npm run test:examples:smoke && npm run test:reference:smoke",
    "test:unit": "npm run test --workspace='packages/**' --if-present",
    "typecheck": "tsc -b --noEmit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@playwright/test": "^1.50.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/stats.js": "^0.17.4",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^4.0.17",
    "@webgpu/types": "^0.1.70",
    "chokidar": "^3.6.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-define-config": "^2.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "picocolors": "^1.1.1",
    "prettier": "3.8.1",
    "stats.js": "^0.17.0",
    "terser": "^5.46.0",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.0.17",
    "vitest-webgl-canvas-mock": "^1.1.0"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": "tsx ./scripts/order.ts --fix",
    "**/*.ts": [
      "eslint -c eslint.config.ts --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "**/*.rs": "rustfmt --edition 2024",
    "**/*.{json,md}": "prettier --write"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "vite": "^7.3.1"
  }
}
