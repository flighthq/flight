{
  "name": "flight",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/**",
    "examples/**",
    "tests/*",
    "tools/*"
  ],
  "scripts": {
    "api": "tsx ./scripts/api.ts",
    "api:json": "tsx ./scripts/api.ts --json",
    "build": "tsc -b tsconfig.build.json",
    "build:check": "npm run packages:check && npm run typecheck",
    "build:clean": "npm run clean && npm run build",
    "build:examples": "npm run build --workspace=examples/**",
    "check": "npm run packages:check && npm run typecheck && npm run lint && npm run format:check && npm run order:check && npm run test:completeness",
    "ci": "npm run build && npm run check && npm run test && npm run size",
    "clean": "tsc -b tsconfig.build.json --clean",
    "clean:examples": "npm run clean --workspace=examples/** --if-present",
    "test:completeness": "tsx ./scripts/completeness.ts",
    "test:completeness:json": "tsx ./scripts/completeness.ts --json",
    "test:coverage": "vitest run --coverage --project=!size",
    "electron-harness": "npm run dev --workspace=tools/electron-harness",
    "explorer": "npm run dev --workspace=tools/explorer",
    "functional": "npm run dev --workspace=tools/functional",
    "landing": "npm run dev --workspace=tools/landing",
    "build:electron-harness": "npm run build --workspace=tools/electron-harness",
    "build:explorer": "npm run build --workspace=tools/explorer",
    "build:landing": "npm run build --workspace=tools/landing",
    "start:electron-harness": "npm run start --workspace=tools/electron-harness",
    "build:site": "tsx ./scripts/build-site.ts",
    "preview:site": "cross-env PAGES_BASE=/ npm run build:site && npx -y serve tools/site",
    "capture:explorer": "tsx ./scripts/capture.ts --tool=explorer",
    "capture:explorer:watch": "tsx ./scripts/watch-capture.ts --tool=explorer",
    "capture:explorer:baseline": "tsx ./scripts/capture.ts --tool=explorer --update-baseline",
    "capture:explorer:check": "tsx ./scripts/capture.ts --tool=explorer --fail-on-changed",
    "capture:functional": "tsx ./scripts/capture.ts --tool=functional",
    "verify:functional": "tsx ./scripts/capture.ts --tool=functional --frames=1 --fail-on-error",
    "capture:functional:watch": "tsx ./scripts/watch-capture.ts --tool=functional",
    "capture:functional:baseline": "tsx ./scripts/capture.ts --tool=functional --update-baseline",
    "capture:functional:check": "tsx ./scripts/capture.ts --tool=functional --fail-on-changed",
    "capture:landing": "tsx ./scripts/capture.ts --tool=landing",
    "capture:landing:watch": "tsx ./scripts/watch-capture.ts --tool=landing",
    "capture:landing:baseline": "tsx ./scripts/capture.ts --tool=landing --update-baseline",
    "capture:landing:check": "tsx ./scripts/capture.ts --tool=landing --fail-on-changed",
    "capture:baseline": "npm run capture:explorer:baseline && npm run capture:functional:baseline && npm run capture:landing:baseline",
    "capture:check": "npm run capture:explorer:check && npm run capture:functional:check && npm run capture:landing:check",
    "fix": "npm run order:fix && npm run lint:fix && npm run format",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint -c eslint.config.ts . --cache --max-warnings=0 --no-warn-ignored",
    "lint:fix": "eslint -c eslint.config.ts . --fix --no-warn-ignored",
    "order": "tsx ./scripts/order.ts",
    "order:check": "tsx ./scripts/order.ts --check",
    "order:check:json": "tsx ./scripts/order.ts --check --json",
    "order:fix": "tsx ./scripts/order.ts --fix",
    "packages:check": "tsx ./scripts/packages.ts",
    "packages:check:json": "tsx ./scripts/packages.ts --json",
    "precommit": "lint-staged",
    "prepush": "npm run build && npm run packages:check && npm run typecheck && npm run test",
    "size": "tsx ./scripts/size.ts",
    "size:baseline": "cross-env UPDATE_BASELINE=1 tsx ./scripts/size.ts",
    "size:json": "tsx ./scripts/size.ts report=json",
    "test": "vitest run --project=!size",
    "test:api": "npm run test:api:node && npm run test:api:browser",
    "test:api:node": "vitest run tests/api",
    "test:api:browser": "vitest run tests/api/browser",
    "test:integration": "vitest run tests/integration",
    "test:size": "tsx ./scripts/test-size.ts",
    "test:size:baseline": "cross-env UPDATE_BASELINE=1 tsx ./scripts/test-size.ts",
    "test:unit": "npm run test --workspace='packages/**' --if-present",
    "typecheck": "tsc -b --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "chokidar": "^3.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/stats.js": "^0.17.4",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^4.0.17",
    "@webgpu/types": "^0.1.70",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-define-config": "^2.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "picocolors": "^1.1.1",
    "prettier": "3.8.1",
    "simple-git-hooks": "^2.13.1",
    "stats.js": "^0.17.0",
    "terser": "^5.46.0",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.0.17",
    "vitest-webgl-canvas-mock": "^1.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run precommit",
    "pre-push": "npm run prepush"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": "tsx ./scripts/order.ts --fix",
    "**/*.ts": [
      "eslint -c eslint.config.ts --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "**/*.{json,md}": "prettier --write"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "vite": "^7.3.1"
  }
}
