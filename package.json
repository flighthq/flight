{
  "name": "flight",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/flighthq/flight.git"
  },
  "type": "module",
  "workspaces": [
    "packages/**",
    "examples/**",
    "tools/*"
  ],
  "scripts": {
    "api": "tsx ./scripts/api.ts",
    "api:check": "tsx ./scripts/api.ts --check",
    "api:json": "tsx ./scripts/api.ts --json",
    "assets": "tsx ./scripts/warm-assets.ts",
    "build": "tsc -b tsconfig.build.json",
    "build:check": "npm run packages:check && npm run typecheck",
    "build:clean": "npm run clean && npm run build",
    "build:electron-harness": "npm run build:examples:electron",
    "build:examples:electron": "npm run build --workspace=@flighthq/examples-electron",
    "build:examples": "npm run build --workspace=@flighthq/examples",
    "build:examples:packages": "npm run build --workspace=examples/packages/**",
    "build:functional": "npm run build --workspace=tools/functional",
    "capture:baseline": "npm run capture:examples:baseline && npm run capture:functional:baseline",
    "capture:check": "npm run capture:examples:check && npm run capture:functional:check",
    "capture:examples": "tsx ./scripts/capture.ts --tool=examples",
    "capture:examples:baseline": "tsx ./scripts/capture.ts --tool=examples --update-baseline",
    "capture:examples:check": "tsx ./scripts/capture.ts --tool=examples --fail-on-changed",
    "capture:examples:watch": "tsx ./scripts/watch-capture.ts --tool=examples",
    "capture:functional": "tsx ./scripts/capture.ts --tool=functional",
    "capture:functional:baseline": "tsx ./scripts/capture.ts --tool=functional --update-baseline",
    "capture:functional:check": "tsx ./scripts/capture.ts --tool=functional --fail-on-changed",
    "capture:functional:watch": "tsx ./scripts/watch-capture.ts --tool=functional",
    "capture:reference": "tsx ./scripts/reference-tool.ts capture",
    "check": "npm run packages:check && npm run typecheck && npm run lint && npm run format:check && npm run order:check && npm run exports:check && npm run api:check && npm run support:check",
    "ci": "npm run build && npm run check && npm run test && npm run size && npm run test:functional && npm run test:examples",
    "clean": "tsc -b tsconfig.build.json --clean",
    "clean:examples": "npm run clean --workspace=examples/packages/** --if-present",
    "clean:reference": "tsx ./scripts/reference-tool.ts clean",
    "dev:electron-harness": "npm run dev --workspace=@flighthq/examples-electron",
    "dev:examples": "npm run dev:examples:web",
    "dev:examples:electron": "tsx ./scripts/electron-tool.ts examples",
    "dev:examples:web": "npm run dev --workspace=@flighthq/examples",
    "dev:functional": "npm run dev --workspace=tools/functional",
    "dev:gallery": "npm run dev --workspace=tools/gallery",
    "dev:reference": "tsx ./scripts/reference-tool.ts dev",
    "electron-harness": "npm run dev:electron-harness",
    "electron:examples": "npm run examples:electron",
    "electron:gallery": "tsx ./scripts/electron-tool.ts gallery",
    "electron:gallery:examples": "tsx ./scripts/electron-tool.ts gallery:examples",
    "electron:gallery:functional": "tsx ./scripts/electron-tool.ts gallery:functional",
    "examples": "npm run dev:examples",
    "examples:electron": "npm run dev:examples:electron",
    "examples:web": "npm run dev:examples:web",
    "exports:check": "tsx ./scripts/completeness.ts",
    "exports:check:json": "tsx ./scripts/completeness.ts --json",
    "fix": "npm run order:fix && npm run lint:fix && npm run format",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "functional": "npm run dev:functional",
    "gallery": "npm run dev:gallery",
    "gallery:examples": "cross-env VITE_GALLERY_TOOL=examples npm run dev --workspace=tools/gallery",
    "gallery:functional": "cross-env VITE_GALLERY_TOOL=functional npm run dev --workspace=tools/gallery",
    "get:reference": "tsx ./scripts/reference-tool.ts get",
    "lint": "oxlint --max-warnings=0",
    "lint:fix": "oxlint --fix",
    "list:reference": "tsx ./scripts/reference-tool.ts list",
    "order": "tsx ./scripts/order.ts",
    "order:check": "tsx ./scripts/order.ts --check",
    "order:check:json": "tsx ./scripts/order.ts --check --json",
    "order:fix": "tsx ./scripts/order.ts --fix",
    "packages:check": "tsx ./scripts/packages.ts",
    "packages:check:json": "tsx ./scripts/packages.ts --json",
    "precommit": "lint-staged",
    "prepare": "husky",
    "prepush": "tsx ./scripts/prepush.ts",
    "preview:examples": "npm run build:examples && npm run preview --workspace=@flighthq/examples",
    "preview:functional": "npm run build:functional && npm run preview --workspace=tools/functional",
    "reference": "npm run dev:reference --",
    "release": "tsx ./scripts/publish-packages.ts",
    "review:snapshot": "tsx ./scripts/review-snapshot.ts",
    "sbx:whitelist": "sbx policy allow network cdn.playwright.dev,playwright.download.prss.microsoft.com,github.com,objects.githubusercontent.com,release-assets.githubusercontent.com,static.crates.io,crates.io",
    "size": "tsx ./scripts/size.ts",
    "size:baseline": "cross-env UPDATE_BASELINE=1 tsx ./scripts/size.ts",
    "size:json": "tsx ./scripts/size.ts report=json",
    "start:electron-harness": "npm run start --workspace=@flighthq/examples-electron",
    "support": "tsx ./scripts/support.ts",
    "support:check": "tsx ./scripts/support.ts --check",
    "test": "vitest run",
    "test:baseline": "npm run test:regression:baseline",
    "test:coverage": "vitest run --coverage",
    "test:examples": "npm run test:examples:smoke && npm run test:examples:parity",
    "test:examples:baseline": "npm run test:examples:regression:baseline",
    "test:examples:parity": "tsx ./scripts/compare-render.ts --tool=examples --frames=30 --renderer=canvas,webgl,webgpu --no-regression",
    "test:examples:regression": "tsx ./scripts/compare-render.ts --tool=examples --frames=30 --renderer=canvas,webgl,webgpu --no-parity",
    "test:examples:regression:baseline": "tsx ./scripts/compare-render.ts --tool=examples --frames=30 --renderer=canvas,webgl,webgpu --update-fingerprints",
    "test:examples:smoke": "tsx ./scripts/capture.ts --tool=examples --frames=30 --renderer=dom,canvas,webgl,webgpu --fail-on-error",
    "test:functional": "npm run test:functional:smoke && npm run test:functional:parity",
    "test:functional:baseline": "npm run test:functional:regression:baseline",
    "test:functional:parity": "tsx ./scripts/compare-render.ts --tool=functional --renderer=canvas,webgl,webgpu --no-regression",
    "test:functional:regression": "tsx ./scripts/compare-render.ts --tool=functional --renderer=canvas,webgl,webgpu --no-parity",
    "test:functional:regression:baseline": "tsx ./scripts/compare-render.ts --tool=functional --renderer=canvas,webgl,webgpu --update-fingerprints",
    "test:functional:smoke": "tsx ./scripts/capture.ts --tool=functional --frames=1 --renderer=dom,canvas,webgl,webgpu --fail-on-error",
    "test:parity": "npm run test:functional:parity && npm run test:examples:parity",
    "test:reference": "tsx ./scripts/reference-tool.ts test",
    "test:regression": "npm run test:functional:regression && npm run test:examples:regression",
    "test:regression:baseline": "npm run test:functional:regression:baseline && npm run test:examples:regression:baseline",
    "test:size": "tsx ./scripts/test-size.ts",
    "test:size:baseline": "cross-env UPDATE_BASELINE=1 tsx ./scripts/test-size.ts",
    "test:smoke": "npm run test:functional:smoke && npm run test:examples:smoke",
    "test:unit": "npm run test --workspace='packages/**' --if-present",
    "typecheck": "tsc -b --noEmit",
    "version:packages": "tsx ./scripts/version-packages.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@playwright/test": "^1.50.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/stats.js": "^0.17.4",
    "@vitest/coverage-v8": "^4.0.17",
    "@webgpu/types": "^0.1.70",
    "chokidar": "^3.6.0",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "oxc-parser": "0.138.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "picocolors": "^1.1.1",
    "stats.js": "^0.17.0",
    "terser": "^5.46.0",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.0.17",
    "vitest-webgl-canvas-mock": "^1.1.0"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": "tsx ./scripts/order.ts --fix",
    "**/*.{ts,tsx}": [
      "oxlint --fix --max-warnings=0 --no-error-on-unmatched-pattern",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ],
    "**/*.{json,md}": "oxfmt --write --no-error-on-unmatched-pattern"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "vite": "^7.3.1"
  }
}
