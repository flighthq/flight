{
  "name": "@flighthq/render-dom",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./background": {
      "types": "./dist/domBackground.d.ts",
      "default": "./dist/domBackground.js"
    },
    "./bitmap": {
      "types": "./dist/domBitmap.d.ts",
      "default": "./dist/domBitmap.js"
    },
    "./displayObject": {
      "types": "./dist/domDisplayObject.d.ts",
      "default": "./dist/domDisplayObject.js"
    },
    "./htmlView": {
      "types": "./dist/htmlView.d.ts",
      "default": "./dist/htmlView.js"
    },
    "./inputText": {
      "types": "./dist/domInputText.d.ts",
      "default": "./dist/domInputText.js"
    },
    "./materials": {
      "types": "./dist/domMaterials.d.ts",
      "default": "./dist/domMaterials.js"
    },
    "./renderState": {
      "types": "./dist/domRenderState.d.ts",
      "default": "./dist/domRenderState.js"
    },
    "./richText": {
      "types": "./dist/domRichText.d.ts",
      "default": "./dist/domRichText.js"
    },
    "./scale9": {
      "types": "./dist/domScale9Shape.d.ts",
      "default": "./dist/domScale9Shape.js"
    },
    "./shape": {
      "types": "./dist/domShape.d.ts",
      "default": "./dist/domShape.js"
    },
    "./text": {
      "types": "./dist/domText.d.ts",
      "default": "./dist/domText.js"
    },
    "./transform": {
      "types": "./dist/domTransform.d.ts",
      "default": "./dist/domTransform.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.test.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --watch --config vitest.config.ts",
    "prepack": "npm run clean && npm run clean:dist && npm run build",
    "clean:dist": "tsx ../../scripts/clean-package-dist.ts"
  },
  "dependencies": {
    "@flighthq/entity": "*",
    "@flighthq/render-tree": "*",
    "@flighthq/geometry": "*",
    "@flighthq/render-canvas": "*",
    "@flighthq/render": "*",
    "@flighthq/scene": "*",
    "@flighthq/scene-display": "*",
    "@flighthq/text-input": "*",
    "@flighthq/text-layout": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "DOM renderer implementation",
  "sideEffects": false
}
