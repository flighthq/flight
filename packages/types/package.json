{
  "name": "@flighthq/types",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./materials": {
      "types": "./dist/materials.d.ts",
      "default": "./dist/materials.js"
    },
    "./geom": {
      "types": "./dist/geom.d.ts",
      "default": "./dist/geom.js"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "default": "./dist/render.js"
    },
    "./stage": {
      "types": "./dist/stage.d.ts",
      "default": "./dist/stage.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
