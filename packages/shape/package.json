{
  "name": "@flighthq/shape",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./graphics": {
      "types": "./dist/graphics.d.ts",
      "default": "./dist/graphics.js"
    },
    "./graphicsCommands": {
      "types": "./dist/graphicsCommands.d.ts",
      "default": "./dist/graphicsCommands.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "Shape vector graphics command buffer and drawing API"
}
