{
  "name": "@flighthq/scene-resources",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/flighthq/flight.git",
    "directory": "packages/scene-resources"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.test.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --watch --config vitest.config.ts",
    "prepack": "npm run clean && npm run clean:dist && npm run build",
    "clean:dist": "tsx ../../scripts/clean-package-dist.ts"
  },
  "dependencies": {
    "@flighthq/entity": "*",
    "@flighthq/image": "*",
    "@flighthq/loader": "*",
    "@flighthq/log": "*",
    "@flighthq/net": "*",
    "@flighthq/node": "*",
    "@flighthq/scene": "*",
    "@flighthq/scene-formats": "*",
    "@flighthq/signals": "*",
    "@flighthq/tween": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "@flighthq/materials": "*",
    "@flighthq/mesh": "*",
    "@flighthq/texture": "*",
    "typescript": "^5.3.0"
  },
  "description": "Renderer-neutral scene-document URL acquisition and caller-driven resolution of scene texture references into live ImageResources",
  "sideEffects": false
}
