{
  "name": "@flighthq/host-electron",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.test.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --watch --config vitest.config.ts",
    "prepack": "npm run clean && npm run clean:dist && npm run build",
    "clean:dist": "tsx ../../scripts/clean-package-dist.ts"
  },
  "dependencies": {
    "@flighthq/app": "*",
    "@flighthq/application": "*",
    "@flighthq/clipboard": "*",
    "@flighthq/dialog": "*",
    "@flighthq/ipc": "*",
    "@flighthq/menu": "*",
    "@flighthq/notification": "*",
    "@flighthq/platform": "*",
    "@flighthq/power": "*",
    "@flighthq/protocol": "*",
    "@flighthq/screen": "*",
    "@flighthq/shell": "*",
    "@flighthq/shortcut": "*",
    "@flighthq/signals": "*",
    "@flighthq/storage": "*",
    "@flighthq/tray": "*",
    "@flighthq/types": "*",
    "@flighthq/updater": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "Electron host backend: registers Electron main-process implementations of Flight's window/app/dialog/clipboard/menu/tray/shortcut/screen/power/notification/shell/protocol/updater/ipc/storage seams",
  "sideEffects": false
}
