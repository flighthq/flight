{
  "name": "@flighthq/render-canvas",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bitmap": {
      "types": "./dist/bitmap.d.ts",
      "default": "./dist/bitmap.js"
    },
    "./cacheBitmap": {
      "types": "./dist/cacheBitmap.d.ts",
      "default": "./dist/cacheBitmap.js"
    },
    "./clipping": {
      "types": "./dist/clipping.d.ts",
      "default": "./dist/clipping.js"
    },
    "./createCanvasRendererState": {
      "types": "./dist/createCanvasRendererState.d.ts",
      "default": "./dist/createCanvasRendererState.js"
    },
    "./displayObject": {
      "types": "./dist/displayObject.d.ts",
      "default": "./dist/displayObject.js"
    },
    "./masks": {
      "types": "./dist/masks.d.ts",
      "default": "./dist/masks.js"
    },
    "./materials": {
      "types": "./dist/materials.d.ts",
      "default": "./dist/materials.js"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "default": "./dist/render.js"
    },
    "./transform": {
      "types": "./dist/transform.d.ts",
      "default": "./dist/transform.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@flighthq/geometry": "*",
    "@flighthq/render-core": "*",
    "@flighthq/scene-graph-stage": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
