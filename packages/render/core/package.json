{
  "name": "@flighthq/render-core",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./appearance": {
      "types": "./dist/appearance.d.ts",
      "default": "./dist/appearance.js"
    },
    "./color": {
      "types": "./dist/color.d.ts",
      "default": "./dist/color.js"
    },
    "./createRendererState": {
      "types": "./dist/createRendererState.d.ts",
      "default": "./dist/createRendererState.js"
    },
    "./queue": {
      "types": "./dist/queue.d.ts",
      "default": "./dist/queue.js"
    },
    "./renderer": {
      "types": "./dist/renderer.d.ts",
      "default": "./dist/renderer.js"
    },
    "./renderNode": {
      "types": "./dist/renderNode.d.ts",
      "default": "./dist/renderNode.js"
    },
    "./transform": {
      "types": "./dist/transform.d.ts",
      "default": "./dist/transform.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@flighthq/geometry": "*",
    "@flighthq/materials": "*",
    "@flighthq/scene-graph-stage": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
