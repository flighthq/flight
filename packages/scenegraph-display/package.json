{
  "name": "@flighthq/scenegraph-display",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bitmap": {
      "types": "./dist/bitmap.d.ts",
      "default": "./dist/bitmap.js"
    },
    "./displayContainer": {
      "types": "./dist/displayContainer.d.ts",
      "default": "./dist/displayContainer.js"
    },
    "./displayObject": {
      "types": "./dist/displayObject.d.ts",
      "default": "./dist/displayObject.js"
    },
    "./htmlView": {
      "types": "./dist/htmlView.d.ts",
      "default": "./dist/htmlView.js"
    },
    "./inputText": {
      "types": "./dist/inputText.d.ts",
      "default": "./dist/inputText.js"
    },
    "./movieClip": {
      "types": "./dist/movieClip.d.ts",
      "default": "./dist/movieClip.js"
    },
    "./richText": {
      "types": "./dist/richText.d.ts",
      "default": "./dist/richText.js"
    },
    "./shape": {
      "types": "./dist/shape.d.ts",
      "default": "./dist/shape.js"
    },
    "./scale9Shape": {
      "types": "./dist/scale9Shape.d.ts",
      "default": "./dist/scale9Shape.js"
    },
    "./shapeCommands": {
      "types": "./dist/shapeCommands.d.ts",
      "default": "./dist/shapeCommands.js"
    },
    "./shapeHitTestRegistry": {
      "types": "./dist/shapeHitTestRegistry.d.ts",
      "default": "./dist/shapeHitTestRegistry.js"
    },
    "./spriteBatch": {
      "types": "./dist/spriteBatch.d.ts",
      "default": "./dist/spriteBatch.js"
    },
    "./stage": {
      "types": "./dist/stage.d.ts",
      "default": "./dist/stage.js"
    },
    "./text": {
      "types": "./dist/text.d.ts",
      "default": "./dist/text.js"
    },
    "./video": {
      "types": "./dist/video.d.ts",
      "default": "./dist/video.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.test.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest --config vitest.config.ts",
    "test:watch": "vitest --watch --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "prepack": "npm run clean && npm run clean:dist && npm run build",
    "clean:dist": "tsx ../../scripts/clean-package-dist.ts"
  },
  "dependencies": {
    "@flighthq/geometry": "*",
    "@flighthq/scenegraph-core": "*",
    "@flighthq/signals": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "Display object tree for composited 2D rendering: bitmaps, shapes, text, masks, blend modes",
  "sideEffects": false
}
