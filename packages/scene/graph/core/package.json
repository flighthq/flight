{
  "name": "@flighthq/scene-graph-core",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./boundsRect": {
      "types": "./dist/boundsRect.d.ts",
      "default": "./dist/boundsRect.js"
    },
    "./hierarchy": {
      "types": "./dist/hierarchy.d.ts",
      "default": "./dist/hierarchy.js"
    },
    "./revision": {
      "types": "./dist/revision.d.ts",
      "default": "./dist/revision.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./sceneNode": {
      "types": "./dist/sceneNode.d.ts",
      "default": "./dist/sceneNode.js"
    },
    "./transform2d": {
      "types": "./dist/transform2d.d.ts",
      "default": "./dist/transform2d.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@flighthq/geometry": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
