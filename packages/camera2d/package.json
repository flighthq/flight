{
  "name": "@flighthq/camera2d",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.test.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --watch --config vitest.config.ts",
    "prepack": "npm run clean && npm run clean:dist && npm run build",
    "clean:dist": "tsx ../../scripts/clean-package-dist.ts"
  },
  "dependencies": {
    "@flighthq/geometry": "*",
    "@flighthq/math": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "2D game camera — world<->screen view matrix, target follow with deadzone + frame-rate-independent smoothing + world-bounds clamp, zoom-about-a-point, parallax offsets, and a visible-bounds cull query over a plain-data camera",
  "sideEffects": false
}
