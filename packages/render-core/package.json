{
  "name": "@flighthq/render-core",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./color": {
      "types": "./dist/color.d.ts",
      "default": "./dist/color.js"
    },
    "./createRenderableData": {
      "types": "./dist/createRenderableData.d.ts",
      "default": "./dist/createRenderableData.js"
    },
    "./createRendererState": {
      "types": "./dist/createRendererState.d.ts",
      "default": "./dist/createRendererState.js"
    },
    "./queue": {
      "types": "./dist/queue.d.ts",
      "default": "./dist/queue.js"
    },
    "./renderable": {
      "types": "./dist/renderable.d.ts",
      "default": "./dist/renderable.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@flighthq/geom": "^1.0.0",
    "@flighthq/materials": "^1.0.0",
    "@flighthq/stage": "^1.0.0",
    "@flighthq/types": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
