{
  "name": "@flighthq/sdk",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.test.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --watch --config vitest.config.ts",
    "prepack": "npm run clean && npm run clean:dist && npm run build",
    "clean:dist": "tsx ../../scripts/clean-package-dist.ts"
  },
  "dependencies": {
    "@flighthq/app": "*",
    "@flighthq/application": "*",
    "@flighthq/camera": "*",
    "@flighthq/clip": "*",
    "@flighthq/clipboard": "*",
    "@flighthq/device": "*",
    "@flighthq/dialog": "*",
    "@flighthq/displayobject": "*",
    "@flighthq/effects": "*",
    "@flighthq/effects-webgl": "*",
    "@flighthq/entity": "*",
    "@flighthq/filesystem": "*",
    "@flighthq/filters": "*",
    "@flighthq/filters-canvas": "*",
    "@flighthq/filters-webgl": "*",
    "@flighthq/filters-webgpu": "*",
    "@flighthq/geolocation": "*",
    "@flighthq/geometry": "*",
    "@flighthq/haptics": "*",
    "@flighthq/input": "*",
    "@flighthq/interaction": "*",
    "@flighthq/ipc": "*",
    "@flighthq/keyboard": "*",
    "@flighthq/lifecycle": "*",
    "@flighthq/log": "*",
    "@flighthq/materials": "*",
    "@flighthq/math": "*",
    "@flighthq/media": "*",
    "@flighthq/menu": "*",
    "@flighthq/network": "*",
    "@flighthq/node": "*",
    "@flighthq/notification": "*",
    "@flighthq/particles": "*",
    "@flighthq/particles-formats": "*",
    "@flighthq/path": "*",
    "@flighthq/platform": "*",
    "@flighthq/power": "*",
    "@flighthq/protocol": "*",
    "@flighthq/render": "*",
    "@flighthq/render-canvas": "*",
    "@flighthq/render-dom": "*",
    "@flighthq/render-webgl": "*",
    "@flighthq/render-webgpu": "*",
    "@flighthq/resources": "*",
    "@flighthq/resources-loader": "*",
    "@flighthq/screen": "*",
    "@flighthq/sensors": "*",
    "@flighthq/shape": "*",
    "@flighthq/share": "*",
    "@flighthq/shell": "*",
    "@flighthq/shortcut": "*",
    "@flighthq/signals": "*",
    "@flighthq/sprite": "*",
    "@flighthq/spritesheet": "*",
    "@flighthq/spritesheet-formats": "*",
    "@flighthq/statusbar": "*",
    "@flighthq/storage": "*",
    "@flighthq/surface": "*",
    "@flighthq/surface-filters": "*",
    "@flighthq/text": "*",
    "@flighthq/text-input": "*",
    "@flighthq/text-layout": "*",
    "@flighthq/timeline": "*",
    "@flighthq/tray": "*",
    "@flighthq/tween": "*",
    "@flighthq/tween-easing": "*",
    "@flighthq/types": "*",
    "@flighthq/updater": "*",
    "@flighthq/world": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "Single entry point re-exporting all packages",
  "sideEffects": false
}
