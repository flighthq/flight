{
  "name": "@flighthq/render-canvas-shape",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./canvasShape": {
      "types": "./dist/canvasShape.d.ts",
      "default": "./dist/canvasShape.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@flighthq/render-canvas": "*",
    "@flighthq/render-core": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "Canvas 2D renderer for Shape vector graphics"
}
